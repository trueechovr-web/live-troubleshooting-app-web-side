# Copy this file to `.env.local` and edit values for your machine.
# .env.local is gitignored.
#
# Backend (api-server) reads via `node --env-file=../../.env.local`.
# Frontend (Vite) reads via envDir set to workspace root.

# ---- Database ----
# Matches docker-compose.yml. Run `docker compose up -d postgres` to start it.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tevr

# ---- api-server ----
PORT=8080
LOG_LEVEL=debug
# Optional. Enables AI session summaries.
# OPENAI_API_KEY=sk-...

# ---- tevr-platform (frontend) ----
# Optional. Enables real-time transcription via Deepgram.
# Vars exposed to the browser must start with VITE_.
# VITE_DEEPGRAM_API_KEY=...
